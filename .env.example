# LinuxLab UFPS — environment variables
#
# Copy to `.env.local` and fill in as features are implemented. Nothing here is
# required yet (the runtime is deferred); these document what the seams expect.
# Access them through lib/config/env.ts.

# PostgreSQL connection string (data layer — lib/data/*).
DATABASE_URL=

# WebSocket URL of the terminal gateway that bridges to the shared Linux server
# where each student has an isolated Unix account (terminal seam — lib/data/terminal.ts).
TERMINAL_GATEWAY_URL=

# Secret used to sign session tokens (auth seam — lib/auth/*).
AUTH_SECRET=
